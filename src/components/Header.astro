---
import { NAV_ITEMS } from '../config';
import ThemeToggle from './ThemeToggle.astro';

const currentPath = Astro.url.pathname;
const navDescriptions: Record<string, string> = {
  Home: 'Start here',
  'Field Guide': 'Production patterns and case studies',
  Tutorials: 'Step-by-step implementation tracks',
  Topics: 'Curated deep dives by domain',
};
---

<header class="site-header dark-hero">
  <div class="container">
    <div class="header-content">
      <a href="/" class="site-title">
        <img src="/images/logo-transparent.png" class="site-logo" alt="" aria-hidden="true" width="44" height="44" />
        <span class="name-first">Praveen</span>
        <span class="name-last">Yellamaraju</span>
      </a>
      
      <div class="header-right">
        <nav class="main-nav">
          <ul>
            {NAV_ITEMS.map(item => {
              const isExternal = item.href.startsWith('http://') || item.href.startsWith('https://');
              const hasChildren = Array.isArray(item.children) && item.children.length > 0;
              const isDropdownOnly = hasChildren && item.href === '#';
              const isActive = currentPath === item.href || (hasChildren && item.children?.some(child => child.href === currentPath));
              return (
                <li class={`nav-item ${hasChildren ? 'has-children' : ''}`}>
                  <div class="nav-item-trigger">
                    {isDropdownOnly ? (
                      <button
                        type="button"
                        class={`nav-dropdown-trigger ${isActive ? 'active' : ''}`}
                        aria-haspopup="true"
                        aria-expanded="false"
                      >
                        {item.label}
                        <span class="nav-caret" aria-hidden="true"></span>
                      </button>
                    ) : (
                      <>
                        <a 
                          href={item.href}
                          class={isActive ? 'active' : ''}
                          aria-current={isActive ? 'page' : undefined}
                          aria-haspopup={hasChildren ? 'true' : undefined}
                          target={isExternal ? '_blank' : undefined}
                          rel={isExternal ? 'noopener noreferrer' : undefined}
                          data-external={isExternal ? 'true' : undefined}
                        >
                          {item.label}
                        </a>
                        {hasChildren && (
                          <button
                            class="nav-submenu-toggle"
                            type="button"
                            aria-expanded="false"
                            aria-label={`Toggle ${item.label} menu`}
                          >
                            <span class="nav-caret" aria-hidden="true"></span>
                          </button>
                        )}
                      </>
                    )}
                  </div>
                  {hasChildren && (
                    <ul class="nav-submenu" aria-label={`${item.label} submenu`}>
                      {item.children?.map(child => {
                        const childExternal = child.href.startsWith('http://') || child.href.startsWith('https://');
                        const childActive = currentPath === child.href;
                        const childIcon = child.label === 'Utilities' ? (
                          <svg class="nav-item-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                            <path d="M12 3v18M3 12h18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                          </svg>
                        ) : child.label === 'Templates' ? (
                          <svg class="nav-item-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                            <path d="M4 4h16v16H4zM8 4v16M4 8h16" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                          </svg>
                        ) : null;
                        return (
                          <li>
                            <a
                              href={child.href}
                              class={childActive ? 'active' : ''}
                              aria-current={childActive ? 'page' : undefined}
                              target={childExternal ? '_blank' : undefined}
                              rel={childExternal ? 'noopener noreferrer' : undefined}
                              data-external={childExternal ? 'true' : undefined}
                            >
                              {childIcon}
                              <span class="nav-submenu-copy">
                                <strong>{child.label}</strong>
                                {(child.description || navDescriptions[child.label]) && (
                                  <small>{child.description || navDescriptions[child.label]}</small>
                                )}
                              </span>
                            </a>
                          </li>
                        );
                      })}
                    </ul>
                  )}
                </li>
              );
            })}
          </ul>
        </nav>
        <ThemeToggle />
      </div>
      
      <button class="mobile-menu-toggle" aria-label="Toggle menu" aria-expanded="false" aria-controls="mobile-menu-overlay">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </div>
  
  <!-- Mobile Menu Overlay -->
  <div class="mobile-menu-overlay" id="mobile-menu-overlay">
    <div class="mobile-menu-header">
      <div class="mobile-menu-brand">
        <strong>Praveen Yellamaraju</strong>
        <span>Production AI Systems Field Guide</span>
      </div>
      <button class="mobile-menu-close" aria-label="Close menu">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>
    <nav class="mobile-menu-nav">
      <ul>
        {NAV_ITEMS.map((item, index) => {
          const isExternal = item.href.startsWith('http://') || item.href.startsWith('https://');
          const hasChildren = Array.isArray(item.children) && item.children.length > 0;
          const isDropdownOnly = hasChildren && item.href === '#';
          const isActive = currentPath === item.href || (hasChildren && item.children?.some(child => child.href === currentPath));
          const submenuId = `mobile-submenu-${index}`;
          return (
            <li class={hasChildren ? 'mobile-has-children' : ''}>
              <div class="mobile-item-row">
                {isDropdownOnly ? (
                  <button
                    type="button"
                    class={`mobile-dropdown-trigger ${isActive ? 'active' : ''}`}
                    aria-expanded="false"
                    aria-controls={submenuId}
                  >
                    {item.label}
                    <span class="mobile-caret" aria-hidden="true">{'>'}</span>
                  </button>
                ) : (
                  <>
                    <a 
                      href={item.href}
                      class={isActive ? 'active' : ''}
                      aria-current={isActive ? 'page' : undefined}
                      target={isExternal ? '_blank' : undefined}
                      rel={isExternal ? 'noopener noreferrer' : undefined}
                      data-external={isExternal ? 'true' : undefined}
                    >
                      {item.label}
                    </a>
                    {hasChildren && (
                      <button
                        class="mobile-submenu-toggle"
                        type="button"
                        aria-expanded="false"
                        aria-controls={submenuId}
                        aria-label={`Toggle ${item.label} menu`}
                      >
                        <span class="mobile-caret" aria-hidden="true">{'>'}</span>
                      </button>
                    )}
                  </>
                )}
              </div>
              {hasChildren && (
                <ul class="mobile-submenu" id={submenuId} aria-label={`${item.label} submenu`}>
                  {item.children?.map(child => {
                    const childExternal = child.href.startsWith('http://') || child.href.startsWith('https://');
                    const childActive = currentPath === child.href;
                    const childIcon = child.label === 'Utilities' ? (
                      <svg class="nav-item-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path d="M12 3v18M3 12h18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                      </svg>
                    ) : child.label === 'Templates' ? (
                      <svg class="nav-item-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path d="M4 4h16v16H4zM8 4v16M4 8h16" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    ) : null;
                    return (
                      <li>
                        <a
                          href={child.href}
                          class={childActive ? 'active' : ''}
                          aria-current={childActive ? 'page' : undefined}
                          target={childExternal ? '_blank' : undefined}
                          rel={childExternal ? 'noopener noreferrer' : undefined}
                          data-external={childExternal ? 'true' : undefined}
                        >
                          {childIcon}
                          <span class="nav-submenu-copy">
                            <strong>{child.label}</strong>
                            {(child.description || navDescriptions[child.label]) && (
                              <small>{child.description || navDescriptions[child.label]}</small>
                            )}
                          </span>
                        </a>
                      </li>
                    );
                  })}
                </ul>
              )}
            </li>
          );
        })}
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
    position: sticky;
    top: 0;
    z-index: 100;
    backdrop-filter: blur(8px);
  }

  .site-header .container {
    max-width: min(1760px, calc(100vw - 3rem));
  }
  
  [data-theme="light"] .site-header,
  [data-theme="auto"] .site-header {
    background: rgba(253, 252, 251, 0.95);
  }
  
  [data-theme="dark"] .site-header {
    background: rgba(26, 26, 26, 0.95);
  }
  
  @media (prefers-color-scheme: dark) {
    [data-theme="auto"] .site-header {
      background: rgba(26, 26, 26, 0.95);
    }
  }

  .site-header.dark-hero {
    background:
      radial-gradient(circle at 70% 18%, rgba(227, 197, 125, 0.14), transparent 28%),
      linear-gradient(135deg, #11100f 0%, #181716 48%, #090a0c 100%);
    border-bottom-color: rgba(248, 242, 230, 0.12);
  }

  .site-header.dark-hero .site-title,
  .site-header.dark-hero .mobile-menu-toggle {
    color: #fffaf0;
  }

  .site-header.dark-hero .name-last,
  .site-header.dark-hero .main-nav a,
  .site-header.dark-hero .nav-dropdown-trigger {
    color: rgba(248, 242, 230, 0.72);
  }

  .site-header.dark-hero .main-nav a:hover,
  .site-header.dark-hero .main-nav a.active,
  .site-header.dark-hero .nav-dropdown-trigger:hover,
  .site-header.dark-hero .nav-dropdown-trigger.active,
  .site-header.dark-hero .nav-item.open .nav-dropdown-trigger {
    color: #f2d98e;
  }

  .site-header.dark-hero .nav-submenu a {
    color: var(--color-text);
  }

  .site-header.dark-hero .nav-submenu a:hover,
  .site-header.dark-hero .nav-submenu a.active {
    color: var(--color-accent);
  }

  .site-header.dark-hero .main-nav a.active::after {
    background: #d8bd7a;
  }

  .site-header.dark-hero .mobile-menu-toggle span {
    background: #fffaf0;
  }

  .site-header.dark-hero :global(.theme-switcher) {
    --theme-switch-bg: rgba(248, 242, 230, 0.08);
    --theme-switch-active: rgba(248, 242, 230, 0.16);
    border-color: rgba(248, 242, 230, 0.14);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.08);
  }
  
  .header-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-md) 0;
    gap: clamp(0.75rem, 1.35vw, 1.5rem);
  }
  
  .header-right {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: clamp(0.75rem, 1.25vw, 1.35rem);
    min-width: 0;
    margin-left: auto;
  }
  
  .site-title {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 700;
    text-decoration: none;
    color: var(--color-text);
    display: flex;
    align-items: center;
    gap: 0.4em;
    transition: opacity var(--transition-fast);
    flex: 0 0 auto;
    white-space: nowrap;
  }

  .site-logo {
    width: 44px;
    height: 44px;
    object-fit: contain;
    flex-shrink: 0;
    display: block;
    filter: drop-shadow(0 0 6px rgba(216, 189, 122, 0.45));
  }
  
  .site-title:hover {
    opacity: 0.7;
  }
  
  .name-last {
    color: var(--color-text-secondary);
  }
  
  .main-nav ul {
    display: flex;
    align-items: center;
    gap: clamp(0.95rem, 1.35vw, 1.55rem);
    list-style: none;
    padding: 0;
    margin: 0;
  }
  
  .main-nav {
    font-family: var(--font-sans);
    min-width: 0;
  }
  
  .main-nav a {
    font-weight: 500;
    font-size: 0.94rem;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color var(--transition-fast);
    position: relative;
    white-space: nowrap;
  }
  
  .main-nav a:hover,
  .main-nav a.active {
    color: var(--color-accent);
  }
  
  .main-nav a.active::after {
    content: '';
    position: absolute;
    bottom: -0.5rem;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--color-accent);
  }

  .nav-item {
    position: relative;
  }

  .nav-item-trigger {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }

  .nav-submenu-toggle {
    border: none;
    background: none;
    padding: 0.15rem 0.25rem;
    color: var(--color-text-secondary);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
  }

  .nav-item.open .nav-submenu-toggle,
  .nav-item:hover .nav-submenu-toggle {
    color: var(--color-accent);
  }

  .nav-dropdown-trigger {
    -webkit-appearance: none;
    -moz-appearance: none;
    appearance: none;
    border: none;
    background: transparent;
    background-color: transparent;
    font-weight: 500;
    font-size: inherit;
    font-family: inherit;
    color: var(--color-text-secondary);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0;
    margin: 0;
    line-height: inherit;
    transition: color var(--transition-fast);
    white-space: nowrap;
  }

  .nav-dropdown-trigger:hover,
  .nav-dropdown-trigger.active {
    color: var(--color-accent);
  }

  .nav-item.open .nav-dropdown-trigger {
    color: var(--color-accent);
  }

  .nav-dropdown-trigger .nav-caret {
    margin-left: 0;
  }

  .nav-caret {
    display: inline-block;
    width: 0;
    height: 0;
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    border-top: 5px solid currentColor;
    opacity: 0.7;
    transition: transform var(--transition-fast);
  }

  .nav-submenu {
    position: absolute;
    top: calc(100% + 1rem);
    left: 50%;
    min-width: 230px;
    padding: 0.45rem;
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--color-surface) 96%, white 4%), var(--color-surface));
    border: 1px solid color-mix(in srgb, var(--color-border) 80%, transparent);
    border-radius: 14px;
    box-shadow:
      0 18px 50px color-mix(in srgb, black 14%, transparent),
      inset 0 1px 0 color-mix(in srgb, white 45%, transparent);
    display: none;
    flex-direction: column;
    align-items: stretch;
    gap: 0.15rem;
    z-index: 200;
    opacity: 0;
    transform: translate(-50%, 8px) scale(0.98);
    transform-origin: top center;
    transition: opacity var(--transition-fast), transform var(--transition-fast);
    -webkit-backdrop-filter: blur(18px);
    backdrop-filter: blur(18px);
    text-align: left;
  }

  .main-nav .nav-submenu {
    align-items: stretch;
  }

  .nav-submenu::before {
    content: '';
    position: absolute;
    top: -6px;
    left: 50%;
    width: 12px;
    height: 12px;
    background: var(--color-surface);
    border-left: 1px solid color-mix(in srgb, var(--color-border) 80%, transparent);
    border-top: 1px solid color-mix(in srgb, var(--color-border) 80%, transparent);
    transform: translateX(-50%) rotate(45deg);
  }

  .nav-submenu li {
    list-style: none;
    margin: 0;
    width: 100%;
  }

  .nav-submenu a {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: 0.5rem;
    width: 100%;
    min-height: 2.45rem;
    padding: 0.55rem 0.75rem;
    border-radius: 10px;
    font-size: 0.95rem;
    line-height: 1.2;
    color: var(--color-text);
    text-align: left;
    transition:
      background var(--transition-fast),
      color var(--transition-fast),
      transform var(--transition-fast);
  }

  .nav-submenu-copy {
    display: grid;
    justify-items: start;
    gap: 0.12rem;
    width: 100%;
    min-width: 0;
    text-align: left;
  }

  .nav-submenu-copy strong {
    display: block;
    font-size: 0.95rem;
    font-weight: 700;
    line-height: 1.1;
    text-align: left;
  }

  .nav-submenu-copy small {
    display: block;
    color: var(--color-text-tertiary);
    font-size: 0.78rem;
    font-weight: 500;
    line-height: 1.25;
    text-align: left;
  }

  .nav-submenu a:hover,
  .nav-submenu a.active {
    background: color-mix(in srgb, var(--color-accent) 10%, transparent);
    color: var(--color-accent);
    transform: translateX(2px);
  }

  .nav-item-icon {
    flex-shrink: 0;
    opacity: 0.7;
  }

  .nav-submenu a.active::after {
    display: none;
  }

  .nav-item.open .nav-submenu {
    display: flex;
    opacity: 1;
    transform: translate(-50%, 0) scale(1);
  }

  .nav-item.open .nav-caret {
    transform: rotate(180deg);
  }
  
  .mobile-menu-toggle {
    display: none;
    flex-direction: column;
    gap: 4px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    flex-shrink: 0;
  }
  
  .mobile-menu-toggle span {
    width: 24px;
    height: 2px;
    background: var(--color-text);
    transition: transform var(--transition-base);
  }
  
  @media (max-width: 768px) {
    .header-content {
      display: flex;
      padding: var(--space-sm) 0;
      gap: var(--space-xs);
      position: relative;
    }
    
    .site-title {
      font-size: 1rem;
      flex: 1;
      min-width: 0;
      overflow: hidden;
    }
    
    .site-title .name-first,
    .site-title .name-last {
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    
    .header-right {
      position: relative;
      flex-shrink: 0;
      display: flex !important;
      align-items: center;
      gap: var(--space-xs);
    }
    
    .mobile-menu-toggle {
      display: flex;
      flex-shrink: 0;
      margin-left: var(--space-xs);
      z-index: 1001;
      position: relative;
    }
    
    .mobile-menu-toggle.open {
      display: none;
    }
    
    .main-nav {
      display: none;
    }
    
    /* Mobile Menu Overlay */
    .mobile-menu-overlay {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      width: 100vw;
      height: 100vh;
      background: var(--color-surface);
      z-index: 1000;
      display: flex;
      flex-direction: column;
      overflow-y: auto;
      -webkit-overflow-scrolling: touch;
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
      transition: opacity var(--transition-fast), visibility var(--transition-fast);
    }
    
    .mobile-menu-overlay.open {
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
    }
    
    .mobile-menu-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: var(--space-md);
      border-bottom: 1px solid var(--color-border);
      min-height: 60px;
      flex-shrink: 0;
    }

    .mobile-menu-brand {
      display: grid;
      gap: 0.15rem;
    }

    .mobile-menu-brand strong {
      font-family: var(--font-serif);
      font-size: 1.15rem;
      color: var(--color-text);
    }

    .mobile-menu-brand span {
      color: var(--color-text-tertiary);
      font-size: 0.85rem;
      font-weight: 600;
    }
    
    .mobile-menu-close {
      background: none;
      border: none;
      cursor: pointer;
      padding: var(--space-xs);
      color: var(--color-text);
      display: flex;
      align-items: center;
      justify-content: center;
      transition: opacity var(--transition-fast);
    }
    
    .mobile-menu-close:hover {
      opacity: 0.7;
    }
    
    .mobile-menu-close svg {
      width: 24px;
      height: 24px;
    }
    
    .mobile-menu-nav {
      flex: 1;
      padding: var(--space-md);
      overflow-y: auto;
    }
    
    .mobile-menu-nav > ul {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 0;
    }
    
    .mobile-menu-nav li {
      width: 100%;
      display: block;
      border-bottom: 1px solid var(--color-border);
    }
    
    .mobile-menu-nav li:last-child {
      border-bottom: none;
    }
    
    .mobile-menu-nav a {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      width: 100%;
      padding: var(--space-md) 0;
      font-weight: 500;
      font-size: 1.125rem;
      color: var(--color-text);
      text-decoration: none;
      transition: color var(--transition-fast);
    }
    
    .mobile-menu-nav a:hover,
    .mobile-menu-nav a.active {
      color: var(--color-accent);
    }
    
    .mobile-menu-nav a.active {
      font-weight: 600;
    }

    .mobile-item-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: var(--space-xs);
    }

    .mobile-has-children > .mobile-item-row > a {
      font-weight: 600;
    }

    .mobile-submenu {
      list-style: none;
      padding-left: 1rem;
      margin-top: 0.25rem;
      display: none;
      flex-direction: column;
      gap: 0.25rem;
    }

    .mobile-has-children.open .mobile-submenu {
      display: flex;
    }

    .mobile-submenu-toggle {
      border: none;
      background: none;
      padding: 0.4rem;
      color: var(--color-text-secondary);
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
    }

    .mobile-dropdown-trigger {
      -webkit-appearance: none;
      -moz-appearance: none;
      appearance: none;
      display: flex;
      align-items: center;
      justify-content: space-between;
      width: 100%;
      border: none;
      background: transparent;
      background-color: transparent;
      padding: var(--space-md) 0;
      margin: 0;
      font-weight: 500;
      font-size: 1.125rem;
      font-family: inherit;
      line-height: inherit;
      color: var(--color-text);
      cursor: pointer;
      text-align: left;
      transition: color var(--transition-fast);
    }

    .mobile-dropdown-trigger:hover,
    .mobile-dropdown-trigger.active {
      color: var(--color-accent);
    }

    .mobile-dropdown-trigger .mobile-caret {
      margin-left: auto;
    }

    .mobile-caret {
      display: inline-block;
      transform: translateY(-1px);
      transition: transform var(--transition-fast);
    }

    .mobile-has-children.open .mobile-caret {
      transform: rotate(90deg);
    }
  }

  @media (min-width: 769px) {
    .header-content {
      display: flex;
      align-items: center;
    }

    .header-right {
      display: flex;
    }

    .main-nav {
      flex: 0 1 auto;
    }

    :global(.theme-switcher) {
      flex: 0 0 auto;
      display: flex;
      align-items: center;
    }

    .mobile-menu-toggle {
      display: none;
    }

    .mobile-menu-overlay {
      display: none !important;
    }
  }

  @media (min-width: 769px) and (max-width: 1500px) {
    .main-nav {
      display: none;
    }

    .header-content {
      display: flex;
      justify-content: space-between;
    }

    .header-right {
      display: flex;
      margin-left: auto;
    }

    .mobile-menu-toggle {
      display: flex;
    }
  }
</style>

<script>
  // Mobile menu toggle
  document.addEventListener('DOMContentLoaded', () => {
    const toggle = document.querySelector('.mobile-menu-toggle');
    const overlay = document.querySelector('.mobile-menu-overlay');
    const close = document.querySelector('.mobile-menu-close');
    const body = document.body;
    let lastFocusedElement: Element | null = null;

    function closeDesktopMenus() {
      document.querySelectorAll('.nav-item.open').forEach(item => {
        item.classList.remove('open');
        const button = item.querySelector('.nav-submenu-toggle, .nav-dropdown-trigger');
        if (button) {
          button.setAttribute('aria-expanded', 'false');
        }
      });
    }
    
    function openMenu() {
      lastFocusedElement = document.activeElement;
      overlay?.classList.add('open');
      toggle?.classList.add('open');
      toggle?.setAttribute('aria-expanded', 'true');
      body.style.overflow = 'hidden';
      const firstFocusable = overlay?.querySelector('button, a, [tabindex]:not([tabindex="-1"])');
      if (firstFocusable instanceof HTMLElement) {
        firstFocusable.focus();
      }
    }
    
    function closeMenu() {
      overlay?.classList.remove('open');
      toggle?.classList.remove('open');
      toggle?.setAttribute('aria-expanded', 'false');
      body.style.overflow = '';
      overlay?.querySelectorAll('.mobile-has-children').forEach(item => {
        item.classList.remove('open');
        const button = item.querySelector('.mobile-submenu-toggle');
        if (button) {
          button.setAttribute('aria-expanded', 'false');
        }
      });
      if (lastFocusedElement instanceof HTMLElement) {
        lastFocusedElement.focus();
      }
    }
    
    toggle?.addEventListener('click', () => {
      if (overlay?.classList.contains('open')) {
        closeMenu();
      } else {
        openMenu();
      }
    });
    
    close?.addEventListener('click', () => {
      closeMenu();
    });

    document.addEventListener('click', (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;
      if (target.closest('.nav-item')) return;
      closeDesktopMenus();
    });

    document.addEventListener('keydown', (event) => {
      if (event.key !== 'Escape') return;
      if (overlay?.classList.contains('open')) {
        closeMenu();
        return;
      }
      closeDesktopMenus();
    });
    
    // Close menu when clicking on overlay background
    overlay?.addEventListener('click', (e) => {
      if (e.target === overlay) {
        closeMenu();
      }
    });
    
    // Close menu when clicking on a link
    const mobileLinks = overlay?.querySelectorAll('.mobile-menu-nav a');
    mobileLinks?.forEach(link => {
      link.addEventListener('click', () => {
        closeMenu();
      });
    });

    const submenuToggles = overlay?.querySelectorAll('.mobile-submenu-toggle');
    submenuToggles?.forEach(button => {
      button.addEventListener('click', (event) => {
        event.preventDefault();
        const parentItem = button.closest('.mobile-has-children');
        if (!parentItem) return;
        const isOpen = parentItem.classList.toggle('open');
        button.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
      });
    });

    // Mobile dropdown triggers (buttons that only open dropdown, no navigation)
    const mobileDropdownTriggers = overlay?.querySelectorAll('.mobile-dropdown-trigger');
    mobileDropdownTriggers?.forEach(button => {
      button.addEventListener('click', (event) => {
        event.preventDefault();
        const parentItem = button.closest('.mobile-has-children');
        if (!parentItem) return;
        const isOpen = parentItem.classList.toggle('open');
        button.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
      });
    });

    const desktopToggles = document.querySelectorAll('.nav-submenu-toggle');
    desktopToggles.forEach(button => {
      button.addEventListener('click', (event) => {
        event.preventDefault();
        event.stopPropagation();
        const parentItem = button.closest('.nav-item');
        if (!parentItem) return;
        const isOpen = parentItem.classList.toggle('open');
        button.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
      });
    });

    // Desktop dropdown triggers (buttons that only open dropdown, no navigation)
    const desktopDropdownTriggers = document.querySelectorAll('.nav-dropdown-trigger');
    desktopDropdownTriggers.forEach(button => {
      button.addEventListener('click', (event) => {
        event.preventDefault();
        event.stopPropagation();
        const parentItem = button.closest('.nav-item');
        if (!parentItem) return;
        // Close other open dropdowns
        document.querySelectorAll('.nav-item.open').forEach(item => {
          if (item !== parentItem) {
            item.classList.remove('open');
            const otherButton = item.querySelector('.nav-dropdown-trigger, .nav-submenu-toggle');
            if (otherButton) {
              otherButton.setAttribute('aria-expanded', 'false');
            }
          }
        });
        const isOpen = parentItem.classList.toggle('open');
        button.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
      });
    });
  });
</script>
