---
---

<div class="theme-switcher" role="group" aria-label="Theme preference">
  <button class="theme-choice" type="button" data-theme-choice="light" aria-label="Use light theme" aria-pressed="false">
    <svg width="16" height="16" viewBox="0 0 20 20" fill="none" aria-hidden="true">
      <path d="M10 3V1M10 19V17M17 10H19M1 10H3M15.657 15.657L16.97 16.97M3.03 3.03L4.343 4.343M15.657 4.343L16.97 3.03M3.03 16.97L4.343 15.657M14 10C14 12.2091 12.2091 14 10 14C7.79086 14 6 12.2091 6 10C6 7.79086 7.79086 6 10 6C12.2091 6 14 7.79086 14 10Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    <span>Light</span>
  </button>
  <button class="theme-choice" type="button" data-theme-choice="dark" aria-label="Use dark theme" aria-pressed="false">
    <svg width="16" height="16" viewBox="0 0 20 20" fill="none" aria-hidden="true">
      <path d="M17.293 13.293C16.3785 14.2075 15.2175 14.8622 13.955 15.1943C12.6925 15.5264 11.3736 15.5254 10.1116 15.1913C8.84963 14.8572 7.68978 14.2004 6.77688 13.2841C5.86398 12.3678 5.22928 11.2225 4.93684 9.97091C4.6444 8.71934 4.70401 7.40208 5.10969 6.17868C5.51537 4.95529 6.25349 3.87081 7.2538 3.04106C8.25411 2.21131 9.47799 1.67024 10.7559 1.48318C12.0338 1.29613 13.3194 1.46914 14.5 1.98499C13.125 3.64507 12.5 5.73375 12.5 7.875C12.5 10.0162 13.125 12.1049 14.5 13.765C15.875 13.25 17.125 12.3913 18.125 11.265C17.9004 12.0105 17.5552 12.7192 17.103 13.365C17.0427 13.4482 16.975 13.5252 16.9006 13.595C16.7525 13.7526 16.5905 13.8957 16.4164 14.0226L17.293 13.293Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    <span>Dark</span>
  </button>
</div>

<style>
  .theme-switcher {
    --switch-bg: var(--theme-switch-bg, color-mix(in srgb, var(--color-code-bg) 78%, transparent));
    --switch-active: var(--theme-switch-active, var(--color-surface));
    display: inline-flex;
    align-items: center;
    gap: 0.15rem;
    padding: 0.18rem;
    background: var(--switch-bg);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    box-shadow: inset 0 1px 0 color-mix(in srgb, white 45%, transparent);
  }

  .theme-choice {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.32rem;
    min-width: 2.2rem;
    min-height: 2rem;
    padding: 0.32rem 0.52rem;
    border: 0;
    border-radius: 999px;
    background: transparent;
    color: var(--color-text-tertiary);
    font: 600 0.74rem/1 var(--font-sans);
    cursor: pointer;
    transition:
      color var(--transition-fast),
      background var(--transition-fast),
      box-shadow var(--transition-fast),
      transform var(--transition-fast);
  }

  .theme-choice:hover {
    color: var(--color-text);
  }

  .theme-choice:active {
    transform: scale(0.96);
  }

  .theme-choice.active {
    color: var(--color-text);
    background: var(--switch-active);
    box-shadow: 0 1px 8px color-mix(in srgb, black 12%, transparent);
  }

  .theme-choice:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .theme-choice svg {
    flex: 0 0 auto;
  }

  @media (max-width: 1700px) {
    .theme-choice span {
      display: none;
    }
  }
</style>

<script>
  // @ts-nocheck
  (function() {
    const THEME_STORAGE_KEY = 'theme-preference';
    const THEMES = ['light', 'dark'];

    function getStoredTheme() {
      if (typeof window === 'undefined') return 'light';
      const stored = localStorage.getItem(THEME_STORAGE_KEY);
      return stored && THEMES.includes(stored) ? stored : 'light';
    }

    function setStoredTheme(theme) {
      if (typeof window === 'undefined') return;
      localStorage.setItem(THEME_STORAGE_KEY, theme);
    }

    function applyTheme(theme) {
      document.documentElement.setAttribute('data-theme', theme);
      document.querySelectorAll('[data-theme-choice]').forEach((button) => {
        const isActive = button.getAttribute('data-theme-choice') === theme;
        button.classList.toggle('active', isActive);
        button.setAttribute('aria-pressed', String(isActive));
      });
    }

    applyTheme(getStoredTheme());

    document.addEventListener('DOMContentLoaded', () => {
      document.querySelectorAll('[data-theme-choice]').forEach((button) => {
        button.addEventListener('click', () => {
          const theme = button.getAttribute('data-theme-choice');
          if (!theme) return;
          setStoredTheme(theme);
          applyTheme(theme);
        });
      });
      applyTheme(getStoredTheme());
    });
  })();
</script>
