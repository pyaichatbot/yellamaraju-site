---
interface Props {
  title: string;
  description: string;
  audience: string;
  outcome: string;
  href: string;
  accent: string;
  moduleCount: number;
  levels: string[];
  tags: string[];
  recommendedLabel: string;
}

const { title, description, audience, outcome, href, accent, moduleCount, levels, tags, recommendedLabel } = Astro.props;
---

<a href={href} class="tutorial-path-card" style={`--path-accent: ${accent}`}>
  <div class="path-card-topline">
    <span>{moduleCount} modules</span>
    <span>{recommendedLabel}</span>
  </div>
  <h3>{title}</h3>
  <p class="path-description">{description}</p>
  <div class="path-proof">
    <strong>Best for</strong>
    <span>{audience}</span>
  </div>
  <div class="path-proof">
    <strong>Outcome</strong>
    <span>{outcome}</span>
  </div>
  <div class="path-footer">
    <div class="path-tags">
      {tags.map((tag) => <span>{tag}</span>)}
    </div>
    <div class="path-levels" aria-label="Available levels">
      {levels.map((level) => <span>{level}</span>)}
    </div>
  </div>
</a>

<style>
  .tutorial-path-card {
    display: flex;
    min-height: 360px;
    flex-direction: column;
    gap: var(--space-sm);
    padding: clamp(1.1rem, 2vw, 1.6rem);
    border: 1px solid color-mix(in srgb, var(--path-accent) 24%, var(--color-border));
    border-radius: 18px;
    background:
      linear-gradient(145deg, color-mix(in srgb, var(--path-accent) 8%, transparent), transparent 38%),
      var(--color-surface);
    color: inherit;
    text-decoration: none;
    position: relative;
    overflow: hidden;
    transition: transform 180ms ease, border-color 180ms ease, box-shadow 180ms ease;
  }

  .tutorial-path-card::after {
    content: '';
    position: absolute;
    inset: auto 1.1rem 1.1rem auto;
    width: 84px;
    height: 84px;
    border-radius: 999px;
    background: color-mix(in srgb, var(--path-accent) 16%, transparent);
    filter: blur(8px);
    pointer-events: none;
  }

  .tutorial-path-card:hover {
    transform: translateY(-4px);
    border-color: var(--path-accent);
    box-shadow: 0 18px 48px rgba(0, 0, 0, 0.09);
  }

  .path-card-topline {
    display: flex;
    justify-content: space-between;
    gap: var(--space-sm);
    color: var(--path-accent);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .tutorial-path-card h3 {
    margin: var(--space-xs) 0 0;
    font-size: clamp(1.35rem, 2.5vw, 1.8rem);
  }

  .path-description {
    color: var(--color-text-secondary);
    font-size: 0.98rem;
    line-height: 1.58;
    margin: 0;
  }

  .path-proof {
    display: grid;
    gap: 0.25rem;
    padding-top: var(--space-xs);
    border-top: 1px solid var(--color-border);
  }

  .path-proof strong {
    color: var(--path-accent);
    font-family: var(--font-sans);
    font-size: 0.76rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .path-proof span {
    color: var(--color-text-secondary);
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .path-footer {
    display: flex;
    justify-content: space-between;
    gap: var(--space-sm);
    align-items: flex-end;
    margin-top: auto;
    position: relative;
    z-index: 1;
  }

  .path-tags,
  .path-levels {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .path-tags span,
  .path-levels span {
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: 0.18rem 0.5rem;
    background: var(--color-surface);
    color: var(--color-text-tertiary);
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 700;
  }

  .path-levels span {
    border-color: color-mix(in srgb, var(--path-accent) 34%, var(--color-border));
    color: var(--path-accent);
  }
</style>
