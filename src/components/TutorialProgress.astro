---
interface Props {
  module: number;
  totalModules: number;
  level: 'beginner' | 'intermediate' | 'advanced';
  trackTitle: string;
  pathTitle?: string;
  pathHref?: string;
}

const { module, totalModules, level, trackTitle, pathTitle, pathHref } = Astro.props;
const percent = Math.round((module / totalModules) * 100);

const levelColors = {
  beginner: 'var(--tut-beginner)',
  intermediate: 'var(--tut-intermediate)',
  advanced: 'var(--tut-advanced)',
};
---

<div class="tutorial-progress" aria-label={`Tutorial ${module} of ${totalModules}`}>
  <div class="progress-meta">
    <span class="progress-track">
      {pathTitle && pathHref ? <a href={pathHref}>{pathTitle}</a> : pathTitle}
      {pathTitle ? ' / ' : ''}{trackTitle}
    </span>
    <span class="progress-count">Module {module} / {totalModules}</span>
  </div>
  <div class="progress-bar-wrapper" role="progressbar" aria-valuenow={percent} aria-valuemin={0} aria-valuemax={100}>
    <div
      class="progress-bar-fill"
      style={`width: ${percent}%; background: ${levelColors[level]}`}
    />
  </div>
</div>

<style>
  .tutorial-progress {
    margin-bottom: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .progress-meta {
    display: flex;
    justify-content: space-between;
    gap: var(--space-md);
    font-size: 0.8rem;
    color: var(--color-text-tertiary);
    font-family: var(--font-sans);
  }

  .progress-track { font-weight: 600; color: var(--color-text-secondary); }
  .progress-track a { color: inherit; text-decoration: none; }
  .progress-track a:hover { color: var(--color-accent); }

  .progress-count { white-space: nowrap; }

  .progress-bar-wrapper {
    height: 4px;
    background: var(--color-border);
    border-radius: 2px;
    overflow: hidden;
  }

  .progress-bar-fill {
    height: 100%;
    border-radius: 2px;
    transition: width 0.4s ease;
  }

  @media (max-width: 640px) {
    .progress-meta { flex-direction: column; gap: 0.25rem; }
  }
</style>
