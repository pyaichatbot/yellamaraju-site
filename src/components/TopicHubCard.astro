---
interface Props {
  slug: string;
  title: string;
  description: string;
  postCount: number;
  templateCount?: number;
}

const { slug, title, description, postCount, templateCount = 0 } = Astro.props;
---

<a href={`/topics/${slug}`} class="topic-hub-card">
  <span class="topic-hub-kicker">Topic Hub</span>
  <h2>{title}</h2>
  <p>{description}</p>
  <div class="topic-hub-meta">
    <span>{postCount} {postCount === 1 ? 'post' : 'posts'}</span>
    {templateCount > 0 && <span>{templateCount} {templateCount === 1 ? 'template' : 'templates'}</span>}
  </div>
</a>

<style>
  .topic-hub-card {
    display: block;
    padding: var(--space-md);
    color: inherit;
    text-decoration: none;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    transition: transform var(--transition-fast), border-color var(--transition-fast), box-shadow var(--transition-fast);
  }

  .topic-hub-card:hover {
    transform: translateY(-2px);
    border-color: var(--color-accent);
    box-shadow: var(--shadow-md);
  }

  .topic-hub-kicker {
    display: block;
    margin-bottom: var(--space-xs);
    color: var(--color-accent);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h2 {
    margin-bottom: var(--space-xs);
    font-size: 1.35rem;
  }

  p {
    margin-bottom: var(--space-sm);
    color: var(--color-text-secondary);
    line-height: 1.55;
  }

  .topic-hub-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }
</style>
