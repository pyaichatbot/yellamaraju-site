---
interface Props {
  code?: string;
  files?: Record<string, string>;
  title?: string;
  height?: string;
  language?: 'python' | 'python-wasm';
  template?: string;
  readonly?: boolean;
  showConsole?: boolean;
  id?: string;
  provider?: 'livecodes' | 'replit';
  replitId?: string;
  runtimeNote?: string;
  quickStart?: string[];
  challenge?: string;
}

const {
  code,
  files,
  title,
  runtimeNote = 'Example code (static). Copy and run locally in your own environment.',
  quickStart = [],
  challenge,
} = Astro.props;

let renderedCode = '';

if (code && code.trim().length > 0) {
  renderedCode = code;
} else if (files && Object.keys(files).length > 0) {
  const entries = Object.entries(files);
  renderedCode = entries
    .map(([filename, content]) => `# File: ${filename}\n${content}`)
    .join('\n\n');
} else {
  renderedCode = '# Code example unavailable';
}
---

<div class="code-playground-wrapper">
  {title && (
    <div class="playground-header">
      <h3 class="playground-title">{title}</h3>
    </div>
  )}

  <div class="playground-context">
    <p class="playground-runtime-note">{runtimeNote}</p>
    {quickStart.length > 0 && (
      <ol class="playground-quickstart">
        {quickStart.map((step) => <li>{step}</li>)}
      </ol>
    )}
    {challenge && (
      <p class="playground-challenge"><strong>Try this:</strong> {challenge}</p>
    )}
  </div>

  <pre class="code-example"><code>{renderedCode}</code></pre>
</div>

<style>
  .code-playground-wrapper {
    margin: var(--space-lg) 0;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    overflow: hidden;
  }

  .playground-header {
    padding: var(--space-md);
    border-bottom: 1px solid var(--color-border);
    background: var(--color-code-bg);
  }

  .playground-title {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-text);
    margin: 0;
  }

  .playground-context {
    margin: var(--space-sm);
    padding: var(--space-sm);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: color-mix(in srgb, var(--color-accent) 4%, var(--color-surface));
  }

  .playground-runtime-note {
    margin: 0 0 0.45rem;
    font-size: 0.9rem;
    color: var(--color-text-secondary);
  }

  .playground-quickstart {
    margin: 0;
    padding-left: 1.2rem;
    font-size: 0.88rem;
    color: var(--color-text-secondary);
  }

  .playground-challenge {
    margin: 0.5rem 0 0;
    font-size: 0.88rem;
    color: var(--color-text);
  }

  .code-example {
    margin: 0;
    padding: var(--space-md);
    background: var(--color-code-bg);
    color: var(--color-text);
    overflow-x: auto;
    font-family: var(--font-mono);
    font-size: 0.88rem;
    line-height: 1.55;
  }
</style>
