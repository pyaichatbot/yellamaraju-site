---
interface Props {
  href: string;
  filename: string;
  label: string;
}

const { href, filename, label } = Astro.props;
---

<a class="llms-download-button" href={href} download={filename} aria-label={label} title={label}>
  <svg viewBox="0 0 24 24" width="20" height="20" fill="none" aria-hidden="true">
    <path d="M12 3v11m0 0 4-4m-4 4-4-4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
    <path d="M5 17v2a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-2" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
  </svg>
</a>

<style>
  .llms-download-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.35rem;
    height: 2.35rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    color: var(--color-accent);
    background: var(--color-surface);
    text-decoration: none;
    transition: border-color 160ms ease, color 160ms ease, background 160ms ease, transform 160ms ease;
  }

  .llms-download-button:hover {
    border-color: var(--color-accent);
    color: var(--color-accent-hover);
    background: color-mix(in srgb, var(--color-accent) 7%, var(--color-surface));
    transform: translateY(-1px);
  }

  .llms-download-button:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 3px;
  }

  .llms-download-button svg {
    flex: 0 0 auto;
  }
</style>
