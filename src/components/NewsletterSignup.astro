---
import { SITE } from '../config';

interface Props {
  title?: string;
  description?: string;
  compact?: boolean;
  showPrivacyNote?: boolean;
  source?: string;
}

const {
  title = '',
  description = '',
  compact = false,
  showPrivacyNote = true,
  source = 'site',
} = Astro.props;

const isConfigured = SITE.newsletter.enabled;
const formId = SITE.newsletter.formId;
---

<section class={`newsletter-signup ${compact ? 'compact' : ''}`} aria-label="Newsletter signup">
  <div class="signup-grid-texture" aria-hidden="true"></div>

  {(title?.trim() || description?.trim()) && (
    <div class="signup-header">
      {title?.trim() && <h3 class="signup-title">{title}</h3>}
      {description?.trim() && <p class="signup-description">{description}</p>}
    </div>
  )}

  <div class="signup-body">
    {isConfigured && formId ? (
      <div class="beehiiv-embed">
        <script
          async
          src="https://subscribe-forms.beehiiv.com/v3/loader.js"
          data-beehiiv-form={formId}
        />
        <noscript>
          <p class="fallback-message">
            JavaScript is required for the newsletter form. You can still follow via
            <a href="/blog/rss.xml">RSS</a>.
          </p>
        </noscript>
      </div>
    ) : (
      <div class="newsletter-fallback">
        <p class="fallback-message">
          Follow via <a href="/blog/rss.xml">RSS</a> while newsletter setup is in progress.
        </p>
        <a href="/contact" class="fallback-link">Get in touch for updates</a>
      </div>
    )}
  </div>

  {showPrivacyNote && (
    <p class="privacy-note">
      No spam. Unsubscribe anytime.{' '}
      <a href="/privacy">Privacy policy</a>.
    </p>
  )}
</section>

<style>
  .newsletter-signup {
    position: relative;
    margin-top: var(--space-xl);
    padding: var(--space-lg);
    background: linear-gradient(135deg, #11100f 0%, #181716 48%, #090a0c 100%);
    border: 1px solid rgba(216, 189, 122, 0.18);
    border-radius: 12px;
    overflow: hidden;
    text-align: center;
  }

  .newsletter-signup.compact {
    margin-top: var(--space-md);
    padding: var(--space-sm) var(--space-md);
  }

  /* Subtle grid texture matching the hero */
  .signup-grid-texture {
    position: absolute;
    inset: 0;
    background-image:
      repeating-linear-gradient(0deg, transparent, transparent 39px, rgba(255,255,255,0.025) 40px),
      repeating-linear-gradient(90deg, transparent, transparent 39px, rgba(255,255,255,0.025) 40px);
    pointer-events: none;
  }

  .signup-header {
    position: relative;
    margin-bottom: var(--space-md);
  }

  .signup-title {
    color: #fffaf0;
    font-size: clamp(1.1rem, 2vw, 1.35rem);
    font-weight: 700;
    margin: 0 0 0.5rem;
    letter-spacing: -0.01em;
  }

  .signup-description {
    color: rgba(248, 242, 230, 0.68);
    font-size: 0.95rem;
    line-height: 1.6;
    margin: 0;
    max-width: 44ch;
    margin-inline: auto;
  }

  .signup-body {
    position: relative;
  }

  .beehiiv-embed {
    max-width: 540px;
    margin: 0 auto;
  }

  .newsletter-fallback {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
  }

  .fallback-message {
    margin: 0;
    color: rgba(248, 242, 230, 0.68);
    font-size: 0.95rem;
  }

  .fallback-message a {
    color: #d8bd7a;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .fallback-link {
    display: inline-block;
    padding: 0.65rem 1.25rem;
    border: 1px solid rgba(216, 189, 122, 0.35);
    border-radius: 6px;
    background: transparent;
    color: #d8bd7a;
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    transition: background var(--transition-fast), border-color var(--transition-fast);
  }

  .fallback-link:hover {
    background: rgba(216, 189, 122, 0.1);
    border-color: rgba(216, 189, 122, 0.6);
  }

  .privacy-note {
    position: relative;
    margin-top: var(--space-sm);
    margin-bottom: 0;
    font-size: 0.78rem;
    color: rgba(248, 242, 230, 0.38);
    letter-spacing: 0.01em;
  }

  .privacy-note a {
    color: rgba(216, 189, 122, 0.6);
    text-decoration: none;
    border-bottom: 1px solid rgba(216, 189, 122, 0.25);
    transition: color var(--transition-fast);
  }

  .privacy-note a:hover {
    color: rgba(216, 189, 122, 0.9);
  }
</style>
