---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import TagBadge from '../../components/TagBadge.astro';
import { getCollection } from 'astro:content';
import { topicHubs } from '../../data/topic-hubs';
import { templates } from '../../data/templates';
import { calculateReadingTime, isPublicPostData } from '../../utils/helpers';

export async function getStaticPaths() {
  return topicHubs.map((hub) => ({
    params: { hub: hub.slug },
    props: { hub },
  }));
}

const { hub } = Astro.props;
const allPosts = await getCollection('blog', ({ data }) => isPublicPostData(data));
const postMap = new Map<string, (typeof allPosts)[number]>(allPosts.map((post) => [post.slug, post]));
const posts = hub.posts.map((slug) => postMap.get(slug)).filter(Boolean);
const featuredPost = postMap.get(hub.featuredPost) ?? posts[0];
const templateItems = templates.filter((template) => hub.templates?.includes(template.slug));
---

<BaseLayout title={hub.title} description={hub.description}>
  <div class="topic-detail-page">
    <div class="container">
      <div class="wide-wrapper">
        <nav class="topic-nav" aria-label="Topic navigation">
          <a href="/topics">All Topics</a>
          <a href="/blog">All Writing</a>
        </nav>

        <header class="topic-header">
          <p class="eyebrow">Topic Hub</p>
          <h1>{hub.title}</h1>
          <p>{hub.description}</p>
          {hub.relatedTags && (
            <div class="related-tags">
              {hub.relatedTags.map((tag) => <TagBadge tag={tag} />)}
            </div>
          )}
        </header>

        {featuredPost && (
          <section class="featured-path">
            <div>
              <p class="section-kicker">Start Here</p>
              <h2>{featuredPost.data.title}</h2>
              <p>{featuredPost.data.description}</p>
            </div>
            <a href={`/blog/${featuredPost.slug}/`} class="primary-button">Read first</a>
          </section>
        )}

        <section class="learning-path">
          <div class="section-heading">
            <p class="section-kicker">Curated Path</p>
            <h2>Read in this order</h2>
          </div>
          <div class="posts-list">
            {posts.map((post, index) => post && (
              <div class="path-item">
                <span class="path-number">{String(index + 1).padStart(2, '0')}</span>
                <PostCard
                  title={post.data.title}
                  description={post.data.description}
                  date={post.data.date}
                  tags={post.data.tags}
                  slug={post.slug}
                  readingTime={calculateReadingTime(post.body)}
                />
              </div>
            ))}
          </div>
        </section>

        {templateItems.length > 0 && (
          <section class="template-section">
            <div class="section-heading">
              <p class="section-kicker">Practitioner Assets</p>
              <h2>Templates for this topic</h2>
            </div>
            <div class="template-grid">
              {templateItems.map((template) => (
                <a href={`/templates/${template.category}/${template.slug}/`} class="template-card">
                  <h3>{template.title}</h3>
                  <p>{template.description}</p>
                </a>
              ))}
            </div>
          </section>
        )}
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .topic-detail-page {
    padding: var(--space-lg) 0 var(--space-xl);
  }

  .topic-nav {
    display: flex;
    gap: var(--space-sm);
    margin-bottom: var(--space-lg);
  }

  .topic-nav a {
    color: var(--color-text-secondary);
    text-decoration: none;
  }

  .topic-nav a:hover {
    color: var(--color-accent);
  }

  .topic-header {
    max-width: 860px;
    margin-bottom: var(--space-xl);
  }

  .eyebrow,
  .section-kicker {
    margin: 0 0 var(--space-xs);
    color: var(--color-accent);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .topic-header h1 {
    margin-bottom: var(--space-sm);
    font-size: clamp(2rem, 5vw, 3.4rem);
    line-height: 1.08;
  }

  .topic-header p {
    color: var(--color-text-secondary);
    font-size: 1.2rem;
    line-height: 1.6;
  }

  .related-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    margin-top: var(--space-md);
  }

  .featured-path {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    margin-bottom: var(--space-xl);
    padding: var(--space-md);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
  }

  .featured-path h2 {
    margin-bottom: var(--space-xs);
  }

  .featured-path p {
    margin-bottom: 0;
    color: var(--color-text-secondary);
  }

  .section-heading {
    margin-bottom: var(--space-md);
  }

  .posts-list {
    display: flex;
    flex-direction: column;
  }

  .path-item {
    display: grid;
    grid-template-columns: 3.25rem 1fr;
    gap: var(--space-sm);
    align-items: start;
  }

  .path-number {
    position: sticky;
    top: 96px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.4rem;
    height: 2.4rem;
    margin-top: var(--space-sm);
    color: var(--color-accent);
    background: var(--color-code-bg);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    font-weight: 700;
    font-size: 0.82rem;
  }

  .template-section {
    margin-top: var(--space-xl);
  }

  .template-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-sm);
  }

  .template-card {
    display: block;
    padding: var(--space-sm);
    color: inherit;
    text-decoration: none;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
  }

  .template-card:hover {
    border-color: var(--color-accent);
  }

  .template-card h3 {
    margin-bottom: var(--space-xs);
    font-size: 1.05rem;
  }

  .template-card p {
    margin: 0;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  @media (max-width: 760px) {
    .featured-path {
      align-items: flex-start;
      flex-direction: column;
    }

    .path-item {
      grid-template-columns: 1fr;
    }

    .path-number {
      position: static;
      margin-top: 0;
    }

    .template-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
