---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageNav from '../../components/PageNav.astro';

// Available tools/blogs under Claude
const claudeTools = [
  {
    name: 'Tutorials',
    slug: 'tutorials',
    description: 'Curated learning paths for Claude, starting with the six-part CCA Foundations series',
    icon: '📚',
    href: '/claude/tutorials'
  },
  {
    name: 'Workflows',
    slug: 'workflows',
    description: 'Structured workflows and patterns for using Claude effectively',
    icon: '⚙️',
    href: '/claude/workflows'
  },
  {
    name: 'Prompts',
    slug: 'prompts',
    description: 'Effective prompt patterns and techniques for Claude',
    icon: '💬',
    href: '/claude/prompts'
  },
  {
    name: 'Limits',
    slug: 'limits',
    description: 'Understanding Claude\'s capabilities, constraints, and best practices',
    icon: '📊',
    href: '/claude/limits'
  }
];
---

<BaseLayout 
  title="Claude - Developer Productivity"
  description="Long-context reasoning & structured thinking. Primary tool for deep analysis."
>
  <main class="claude-page">
    <div class="container">
      <div class="wide-wrapper">
        <PageNav backUrl="/developer-productivity" backLabel="Back to Developer Productivity" />
        
        <header class="page-header">
          <div class="tool-icon">🧠</div>
          <h1>Claude</h1>
          <p class="tagline">Long-context reasoning & structured thinking</p>
          <p class="description">
            Primary tool for deep analysis. This microsite covers workflows, prompts, limits, and practical patterns for getting the most out of Claude.
          </p>
        </header>
        
        <section class="tools-grid">
          {claudeTools.map(tool => (
            <article class="tool-card">
              <div class="tool-icon">{tool.icon}</div>
              <h2 class="tool-name">{tool.name}</h2>
              <p class="tool-description">{tool.description}</p>
              <a href={tool.href} class="tool-link">
                Explore
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                  <path d="M6 12L10 8L6 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            </article>
          ))}
        </section>
        
        <section class="philosophy-section">
          <h2>About This Microsite</h2>
          <div class="philosophy-grid">
            <div class="philosophy-card">
              <h3>Experiential, Not Theoretical</h3>
              <p>Every page reflects actual usage patterns, not feature lists. What works, what fails, when to switch.</p>
            </div>
            <div class="philosophy-card">
              <h3>Senior Dev Filter</h3>
              <p>"What would I tell someone in 5 minutes before they start?" That's the content bar.</p>
            </div>
            <div class="philosophy-card">
              <h3>Practical Patterns</h3>
              <p>Real workflows, tested prompts, and honest assessments of limits and capabilities.</p>
            </div>
          </div>
        </section>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .claude-page {
    padding: var(--space-xl) 0;
    min-height: 70vh;
  }
  
  .page-header {
    text-align: center;
    margin-bottom: var(--space-xl);
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }
  
  .page-header .tool-icon {
    font-size: 4rem;
    margin-bottom: var(--space-sm);
  }
  
  .page-header h1 {
    font-size: 2.75rem;
    margin-bottom: var(--space-sm);
    color: var(--color-text);
  }
  
  .tagline {
    font-size: 1.25rem;
    color: var(--color-accent);
    font-weight: 500;
    margin-bottom: var(--space-sm);
  }
  
  .description {
    font-size: 1.1rem;
    line-height: 1.6;
    color: var(--color-text-secondary);
  }
  
  /* Tools Grid */
  .tools-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-lg);
    margin-bottom: var(--space-xl);
  }
  
  .tool-card {
    position: relative;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: var(--space-lg);
    transition: all var(--transition-base);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }
  
  .tool-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-4px);
    box-shadow: 0 12px 24px rgba(0, 0, 0, 0.1);
  }
  
  .tool-card .tool-icon {
    font-size: 2.5rem;
    margin-bottom: var(--space-xs);
  }
  
  .tool-name {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text);
    margin: 0;
  }
  
  .tool-description {
    font-size: 1rem;
    color: var(--color-text-secondary);
    margin: 0;
    line-height: 1.5;
    flex-grow: 1;
  }
  
  .tool-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: var(--space-sm);
    padding: 0.5rem 1rem;
    background: var(--color-accent);
    color: white;
    font-weight: 600;
    font-size: 0.875rem;
    border-radius: 6px;
    text-decoration: none;
    transition: all var(--transition-fast);
    width: fit-content;
  }
  
  .tool-link:hover {
    background: var(--color-accent-hover);
  }
  
  /* Philosophy Section */
  .philosophy-section {
    margin-bottom: var(--space-xl);
    padding-top: var(--space-xl);
    border-top: 1px solid var(--color-border);
  }
  
  .philosophy-section h2 {
    font-size: 1.5rem;
    text-align: center;
    margin-bottom: var(--space-lg);
    color: var(--color-text);
  }
  
  .philosophy-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: var(--space-md);
  }
  
  .philosophy-card {
    background: var(--color-code-bg);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: var(--space-md);
  }
  
  .philosophy-card h3 {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: var(--space-xs);
  }
  
  .philosophy-card p {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 0;
  }
  
  @media (max-width: 768px) {
    .page-header h1 {
      font-size: 2rem;
    }
    
    .tagline {
      font-size: 1.1rem;
    }
    
    .tools-grid {
      grid-template-columns: 1fr;
    }
    
    .tool-card {
      padding: var(--space-md);
    }
  }
</style>
