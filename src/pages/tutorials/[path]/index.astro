---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TutorialCard from '../../../components/TutorialCard.astro';
import { TUTORIAL_LEVELS, TUTORIAL_PATHS, LEGACY_LEVELS, getTutorialPath, tutorialHref } from '../../../data/tutorial-paths';

export async function getStaticPaths() {
  return [
    ...TUTORIAL_PATHS.map((path) => ({ params: { path: path.id }, props: { legacyLevel: undefined } })),
    ...LEGACY_LEVELS.map((level) => ({ params: { path: level }, props: { legacyLevel: level } })),
  ];
}

const { path: pathParam } = Astro.params as { path: string };
const { legacyLevel } = Astro.props as { legacyLevel?: string };

if (legacyLevel) {
  return Astro.redirect(`/tutorials/genai/${legacyLevel}`, 301);
}

const pathInfo = getTutorialPath(pathParam);
if (!pathInfo) return Astro.redirect('/tutorials', 302);

const allTutorials = await getCollection('tutorials', ({ data }) => !data.draft && data.path === pathParam);
const byLevel = Object.fromEntries(
  TUTORIAL_LEVELS.map((level) => [
    level.key,
    allTutorials.filter((t) => t.data.level === level.key).sort((a, b) => a.data.module - b.data.module),
  ])
) as Record<string, typeof allTutorials>;

const availableLevels = TUTORIAL_LEVELS.filter((level) => byLevel[level.key]?.length > 0);
const isSingleTrack = pathInfo.id === 'ai-literacy';
const displayLevel = (level: typeof TUTORIAL_LEVELS[number]) => isSingleTrack ? 'Single Track' : level.label;
const displaySubtitle = (level: typeof TUTORIAL_LEVELS[number]) => isSingleTrack ? `Governance and risk track · ${byLevel[level.key].length} tutorials · ~3 hours total` : `${level.subtitle} · ${byLevel[level.key].length} tutorials · ${level.time}`;
---

<BaseLayout
  title={`${pathInfo.title} Tutorials`}
  description={pathInfo.description}
  socialImage="/images/tutorials-social.png"
  socialImageWidth={1200}
  socialImageHeight={630}
  socialImageType="image/png"
>
  <div class="path-page" style={`--path-accent: ${pathInfo.accent}`}>
    <header class="path-header">
      <a href="/tutorials" class="back-link">← All Tutorial Paths</a>
      <p class="eyebrow">Learning Path</p>
      <h1>{pathInfo.title}</h1>
      <p class="path-description">{pathInfo.description}</p>
      <div class="path-outcomes">
        <div><strong>Best for</strong><span>{pathInfo.audience}</span></div>
        <div><strong>Outcome</strong><span>{pathInfo.outcome}</span></div>
      </div>
      <nav class="level-tabs" aria-label={`${pathInfo.title} levels`}>
        {availableLevels.map((level) => (
          <a href={`/tutorials/${pathInfo.id}/${level.key}`}>{displayLevel(level)} <span>{byLevel[level.key].length}</span></a>
        ))}
      </nav>
      <div class="role-filters" aria-label="Filter tutorials by role">
        <button class="role-filter-btn active" data-filter-role="all" aria-pressed="true">All Roles</button>
        <button class="role-filter-btn" data-filter-role="dev" aria-pressed="false">DEV</button>
        <button class="role-filter-btn" data-filter-role="qa" aria-pressed="false">QA</button>
        <button class="role-filter-btn" data-filter-role="ba" aria-pressed="false">BA</button>
        <button class="role-filter-btn" data-filter-role="pm" aria-pressed="false">PM</button>
        <button class="role-filter-btn" data-filter-role="exec" aria-pressed="false">Exec</button>
      </div>
    </header>

    {availableLevels.map((level) => (
      <section class="track-section" id={level.key}>
        <div class="track-header">
          <div class="track-meta">
            <span class="track-level-dot" style={`background: ${level.color}`} />
            <div>
              <h2 class="track-title">{displayLevel(level)}</h2>
              <p class="track-subtitle">{displaySubtitle(level)}</p>
            </div>
          </div>
          <a href={`/tutorials/${pathInfo.id}/${level.key}`} class="track-cta">View {displayLevel(level)} →</a>
        </div>
        <div class="track-grid">
          {byLevel[level.key].map((t) => (
            <TutorialCard
              title={t.data.title}
              description={t.data.description}
              level={t.data.level}
              module={t.data.module}
              totalModules={t.data.totalModules}
              roles={t.data.roles}
              estimatedTime={t.data.estimatedTime}
              href={tutorialHref(t)}
              levelLabel={isSingleTrack ? 'Single Track' : undefined}
            />
          ))}
        </div>
      </section>
    ))}
  </div>
</BaseLayout>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const buttons = document.querySelectorAll('.role-filter-btn');
    const cards = document.querySelectorAll('.tutorial-card');
    const sections = document.querySelectorAll('.track-section');

    function applyFilter(role) {
      cards.forEach((card) => {
        const roles = (card.getAttribute('data-roles') || '').split(',');
        const show = role === 'all' || roles.includes(role);
        card.style.display = show ? '' : 'none';
      });

      sections.forEach((section) => {
        const sectionCards = Array.from(section.querySelectorAll('.tutorial-card'));
        const hasVisible = sectionCards.some((card) => card.style.display !== 'none');
        section.style.display = hasVisible ? '' : 'none';
      });
    }

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const role = btn.getAttribute('data-filter-role') || 'all';
        buttons.forEach((b) => {
          b.classList.remove('active');
          b.setAttribute('aria-pressed', 'false');
        });
        btn.classList.add('active');
        btn.setAttribute('aria-pressed', 'true');
        applyFilter(role);
      });
    });
  });
</script>

<style>
  .path-page { max-width: 1120px; margin: 0 auto; padding: var(--space-xl) var(--space-md); }
  .path-header { margin-bottom: var(--space-xl); }
  .back-link { font-size: 0.875rem; color: var(--color-text-tertiary); text-decoration: none; display: inline-block; margin-bottom: var(--space-md); }
  .back-link:hover { color: var(--path-accent); }
  .eyebrow { margin: 0 0 var(--space-xs); color: var(--path-accent); font-family: var(--font-mono); font-size: 0.78rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; }
  .path-header h1 { max-width: 820px; font-size: clamp(2.2rem, 6vw, 4.3rem); line-height: 0.98; margin-bottom: var(--space-md); letter-spacing: -0.05em; }
  .path-description { max-width: 760px; color: var(--color-text-secondary); font-size: 1.08rem; line-height: 1.65; }
  .path-outcomes { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: var(--space-md); margin: var(--space-lg) 0 var(--space-md); }
  .path-outcomes div { border: 1px solid color-mix(in srgb, var(--path-accent) 24%, var(--color-border)); border-radius: 14px; padding: var(--space-md); background: color-mix(in srgb, var(--path-accent) 5%, var(--color-surface)); }
  .path-outcomes strong { display: block; color: var(--path-accent); font-family: var(--font-sans); font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.35rem; }
  .path-outcomes span { color: var(--color-text-secondary); font-size: 0.96rem; line-height: 1.5; }
  .level-tabs, .role-filters { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-top: var(--space-sm); }
  .level-tabs a { border: 1px solid var(--color-border); border-radius: 999px; padding: 0.4rem 0.8rem; color: var(--color-text); background: var(--color-surface); text-decoration: none; font-family: var(--font-sans); font-size: 0.86rem; font-weight: 700; }
  .level-tabs a:hover { border-color: var(--path-accent); color: var(--path-accent); }
  .level-tabs span { color: var(--color-text-tertiary); margin-left: 0.25rem; }
  .role-filter-btn { border: 1px solid var(--color-border); background: var(--color-surface); color: var(--color-text-secondary); border-radius: 999px; padding: 0.3rem 0.8rem; font-size: 0.78rem; font-weight: 700; cursor: pointer; font-family: var(--font-mono); }
  .role-filter-btn.active { border-color: var(--path-accent); color: var(--path-accent); background: color-mix(in srgb, var(--path-accent) 8%, var(--color-surface)); }
  .track-section { margin-bottom: var(--space-xl); }
  .track-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: var(--space-md); flex-wrap: wrap; gap: var(--space-sm); }
  .track-meta { display: flex; align-items: center; gap: var(--space-sm); }
  .track-level-dot { width: 12px; height: 12px; border-radius: 50%; flex-shrink: 0; }
  .track-title { font-size: 1.5rem; margin: 0; }
  .track-subtitle { font-size: 0.9rem; color: var(--color-text-secondary); margin: 0.2rem 0 0; }
  .track-cta { font-size: 0.9rem; color: var(--path-accent); text-decoration: none; font-weight: 600; }
  .track-cta:hover { text-decoration: underline; }
  .track-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: var(--space-md); }
  @media (max-width: 760px) { .path-outcomes { grid-template-columns: 1fr; } .track-grid { grid-template-columns: 1fr; } }
</style>
