---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TutorialProgress from '../../../components/TutorialProgress.astro';
import TutorialNav from '../../../components/TutorialNav.astro';

export async function getStaticPaths() {
  const tutorials = await getCollection('tutorials', ({ data }) => !data.draft);
  const blogs = await getCollection('blog', ({ data }) => !data.draft && !data.hide);
  return tutorials.map(tutorial => {
    const slugParts = tutorial.slug.split('/');
    const level = slugParts[0];
    const slug = slugParts[1];
    return { params: { level, slug }, props: { tutorial, tutorials, blogs } };
  });
}

const { tutorial, tutorials, blogs } = Astro.props;
const { Content } = await tutorial.render();
const { level, module: mod, totalModules, title, description, estimatedTime, roles, prerequisites = [] } = tutorial.data;
const tutorialKey = `${level}/${tutorial.slug.split('/')[1]}`;

const trackTitle = { beginner: 'Beginner Track', intermediate: 'Intermediate Track', advanced: 'Advanced Track' }[level];
const playgroundBase = 'https://pyaichatbot.github.io/ai-learning-playground/';
function playgroundHref(route: string) {
  return `${playgroundBase}?route=${encodeURIComponent(route)}`;
}

const playgroundMap: Record<string, Array<{ label: string; href: string }>> = {
  'beginner/04-writing-effective-prompts': [
    { label: 'Prompt Reality Lab', href: playgroundHref('/advanced/prompt-reality') },
  ],
  'beginner/09-real-world-ai-app-structure': [
    { label: 'Advanced Landing (System Map)', href: playgroundHref('/advanced/landing') },
  ],
  'intermediate/01-build-first-rag': [
    { label: 'RAG Playground', href: playgroundHref('/basic/rag') },
  ],
  'intermediate/02-ai-agents-from-zero': [
    { label: 'Agent Basics Playground', href: playgroundHref('/basic/agents') },
    { label: 'Agent Runtime Cockpit', href: playgroundHref('/advanced/agent-runtime') },
  ],
  'intermediate/03-tool-use-function-calling': [
    { label: 'MCP Inspector', href: playgroundHref('/advanced/mcp-inspector') },
    { label: 'Agent Runtime Cockpit', href: playgroundHref('/advanced/agent-runtime') },
  ],
  'intermediate/05-context-window-management': [
    { label: 'Prompt Reality Lab', href: playgroundHref('/advanced/prompt-reality') },
  ],
  'advanced/01-production-rag-architectures': [
    { label: 'RAG Playground', href: playgroundHref('/basic/rag') },
  ],
  'advanced/02-multi-agent-orchestration': [
    { label: 'Multi-Agent Basics', href: playgroundHref('/basic/multi-agent') },
    { label: 'A2A Protocol Cockpit', href: playgroundHref('/advanced/a2a-protocol') },
    { label: 'Subagent Dispatch Cockpit', href: playgroundHref('/advanced/subagent-dispatch') },
    { label: 'Advanced Multi-Agent Cockpit', href: playgroundHref('/advanced/multi-agent') },
  ],
  'advanced/05-finetuning-vs-rag-vs-prompting': [
    { label: 'LLM Training Playground', href: playgroundHref('/basic/llm-training') },
    { label: 'RAG Playground', href: playgroundHref('/basic/rag') },
  ],
  'advanced/08-deploying-ai-systems': [
    { label: 'AG-UI Stream Cockpit', href: playgroundHref('/advanced/agui-stream') },
  ],
  'advanced/09-enterprise-mcp-tool-architecture': [
    { label: 'MCP Inspector', href: playgroundHref('/advanced/mcp-inspector') },
    { label: 'Agent Runtime Cockpit', href: playgroundHref('/advanced/agent-runtime') },
  ],
  'advanced/10-agent-runtime-durability-hitl': [
    { label: 'Agent Runtime Cockpit', href: playgroundHref('/advanced/agent-runtime') },
    { label: 'Subagent Dispatch Cockpit', href: playgroundHref('/advanced/subagent-dispatch') },
  ],
  'advanced/11-context-and-memory-engineering': [
    { label: 'Prompt Reality Lab', href: playgroundHref('/advanced/prompt-reality') },
  ],
  'advanced/12-agent-evaluation-harness-trace-grading': [
    { label: 'Subagent Evals', href: 'https://pyaichatbot.github.io/subagent-evals/' },
    { label: 'Prompt Reality Lab', href: playgroundHref('/advanced/prompt-reality') },
  ],
  'advanced/13-ai-governance-guardrails-and-leak-defense': [
    { label: 'MCP Inspector', href: playgroundHref('/advanced/mcp-inspector') },
    { label: 'Prompt Reality Lab', href: playgroundHref('/advanced/prompt-reality') },
  ],
  'advanced/14-agent-interoperability-and-a2a-patterns': [
    { label: 'A2A Protocol Cockpit', href: playgroundHref('/advanced/a2a-protocol') },
    { label: 'Advanced Multi-Agent Cockpit', href: playgroundHref('/advanced/multi-agent') },
  ],
  'advanced/15-long-running-agents-and-async-operations': [
    { label: 'Agent Runtime Cockpit', href: playgroundHref('/advanced/agent-runtime') },
    { label: 'AG-UI Stream Cockpit', href: playgroundHref('/advanced/agui-stream') },
  ],
};

const playgroundLinks = playgroundMap[tutorialKey] ?? [];

const siblings = tutorials
  .filter(t => t.data.level === level && !t.data.draft)
  .sort((a, b) => a.data.module - b.data.module);

const idx = siblings.findIndex(t => t.data.module === mod);
const prevTutorial = idx > 0 ? siblings[idx - 1] : undefined;
const nextTutorial = idx < siblings.length - 1 ? siblings[idx + 1] : undefined;

const tutorialTags = new Set((tutorial.data.tags ?? []).map((t: string) => t.toLowerCase()));
const relatedBlogs = blogs
  .map((post) => {
    const overlap = (post.data.tags ?? []).reduce((count: number, tag: string) => {
      return tutorialTags.has(tag.toLowerCase()) ? count + 1 : count;
    }, 0);
    return { post, overlap };
  })
  .filter((x) => x.overlap > 0)
  .sort((a, b) => b.overlap - a.overlap || b.post.data.date.getTime() - a.post.data.date.getTime())
  .slice(0, 3)
  .map((x) => x.post);

function tutorialHref(t: typeof tutorial) {
  const [lvl, sl] = t.slug.split('/');
  return `/tutorials/${lvl}/${sl}`;
}
---

<BaseLayout title={title} description={description}>
  <article class="tutorial-article">
    <TutorialProgress module={mod} totalModules={totalModules} level={level} trackTitle={trackTitle} />

    <header class="tutorial-header">
      <div class="tutorial-header-meta">
        <span class="tut-level-label" data-level={level}>{level}</span>
        <span class="tut-time">⏱ {estimatedTime}</span>
        <div class="tut-roles">
          {roles.map(r => <span class="tut-role-chip" data-role={r}>{r.toUpperCase()}</span>)}
        </div>
      </div>
      <h1>{title}</h1>
      <p class="tutorial-description">{description}</p>
    </header>

    <section class="learner-guide" aria-label="How to use this tutorial">
      <h2>How to Use This Lesson</h2>
      <ul>
        <li>Read the concept section first, then review diagrams and examples in order.</li>
        <li>If a code example is included, change one input and rerun to see behavior shifts.</li>
        <li>Use the role callouts as your implementation/testing checklist.</li>
      </ul>
      {prerequisites.length > 0 && (
        <p class="learner-prereqs">
          Prerequisites: {prerequisites.join(', ')}
        </p>
      )}
    </section>

    {playgroundLinks.length > 0 && (
      <section class="lab-links" aria-label="Hands-on lab links">
        <h2>Hands-On Lab</h2>
        <p>Use the matching interactive playground for this lesson.</p>
        <div class="lab-links-grid">
          {playgroundLinks.map((link) => (
            <a
              href={link.href}
              target="_blank"
              rel="noopener noreferrer"
              class="lab-link"
              aria-label={`${link.label} (opens in new tab)`}
            >
              {link.label} →
            </a>
          ))}
        </div>
      </section>
    )}

    {relatedBlogs.length > 0 && (
      <section class="related-blogs" aria-label="Related blog references">
        <h2>Related Blog Deep Dives</h2>
        <p>Use these field notes for deeper production context.</p>
        <ul class="related-blog-list">
          {relatedBlogs.map((post) => (
            <li>
              <a href={`/blog/${post.slug}`}>{post.data.title}</a>
            </li>
          ))}
        </ul>
      </section>
    )}

    <TutorialNav
      prev={prevTutorial ? { title: prevTutorial.data.title, href: tutorialHref(prevTutorial), module: prevTutorial.data.module } : undefined}
      next={nextTutorial ? { title: nextTutorial.data.title, href: tutorialHref(nextTutorial), module: nextTutorial.data.module } : undefined}
      trackTitle={trackTitle}
      trackHref={`/tutorials/${level}`}
    />

    <div class="tutorial-content prose post-content">
      <Content />
    </div>

    <TutorialNav
      prev={prevTutorial ? { title: prevTutorial.data.title, href: tutorialHref(prevTutorial), module: prevTutorial.data.module } : undefined}
      next={nextTutorial ? { title: nextTutorial.data.title, href: tutorialHref(nextTutorial), module: nextTutorial.data.module } : undefined}
      trackTitle={trackTitle}
      trackHref={`/tutorials/${level}`}
    />
  </article>
</BaseLayout>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const tutorialContent = document.querySelector('.tutorial-content');
    if (!tutorialContent) return;

    // Wrap tutorial tables exactly like blog pages so horizontal scrolling works.
    const tables = tutorialContent.querySelectorAll('table');
    tables.forEach((table) => {
      const parent = table.parentElement;
      if (!parent || parent.classList.contains('table-wrapper')) return;
      const wrapper = document.createElement('div');
      wrapper.className = 'table-wrapper';
      table.parentNode?.insertBefore(wrapper, table);
      wrapper.appendChild(table);
    });

    const tableWrappers = tutorialContent.querySelectorAll('.table-wrapper');
    const checkScroll = (wrapper) => {
        const isScrollable = wrapper.scrollWidth > wrapper.clientWidth;
        const isAtEnd = wrapper.scrollLeft + wrapper.clientWidth >= wrapper.scrollWidth - 5;
        wrapper.classList.toggle('scrolled-end', isAtEnd);
        (wrapper).style.setProperty('--show-indicator', isScrollable ? 'block' : 'none');
    };

    tableWrappers.forEach((wrapper) => {
      checkScroll(wrapper);
      wrapper.addEventListener('scroll', () => checkScroll(wrapper), { passive: true });
      setTimeout(() => checkScroll(wrapper), 120);
    });

    window.addEventListener('resize', () => {
      tableWrappers.forEach((wrapper) => checkScroll(wrapper));
    });
  });
</script>

<style>
  .tutorial-article { max-width: 800px; margin: 0 auto; padding: var(--space-xl) var(--space-md); }

  .tutorial-header { margin: var(--space-lg) 0; }
  .tutorial-header-meta { display: flex; align-items: center; gap: var(--space-sm); flex-wrap: wrap; margin-bottom: var(--space-md); }
  .tutorial-header h1 { font-size: 2rem; margin-bottom: var(--space-sm); }
  .tutorial-description { font-size: 1.1rem; color: var(--color-text-secondary); margin: 0; line-height: 1.6; }

  .tut-level-label {
    font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em;
    padding: 0.2rem 0.7rem; border-radius: 4px;
  }
  [data-level="beginner"]     { background: color-mix(in srgb, var(--tut-beginner) 12%, transparent); color: var(--tut-beginner); }
  [data-level="intermediate"] { background: color-mix(in srgb, var(--tut-intermediate) 12%, transparent); color: var(--tut-intermediate); }
  [data-level="advanced"]     { background: color-mix(in srgb, var(--tut-advanced) 12%, transparent); color: var(--tut-advanced); }

  .tut-time { font-size: 0.85rem; color: var(--color-text-tertiary); }

  .tut-roles { display: flex; gap: 0.4rem; }
  .tut-role-chip { font-size: 0.7rem; font-weight: 600; padding: 0.15rem 0.5rem; border-radius: 3px; font-family: var(--font-mono); }
  [data-role="dev"] { background: #dbeafe; color: #1d4ed8; }
  [data-role="qa"]  { background: #dcfce7; color: #15803d; }
  [data-role="ba"]  { background: #fef3c7; color: #b45309; }
  [data-role="pm"]  { background: #f3e8ff; color: #7c3aed; }

  .tutorial-content { line-height: 1.75; font-size: var(--text-base); }

  .learner-guide {
    margin: 0 0 var(--space-lg);
    padding: var(--space-md);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    background: color-mix(in srgb, var(--color-accent) 5%, var(--color-surface));
  }

  .learner-guide h2 {
    margin: 0 0 var(--space-xs);
    font-size: 1.05rem;
  }

  .learner-guide ul {
    margin: 0;
    padding-left: 1.2rem;
    color: var(--color-text-secondary);
  }

  .learner-prereqs {
    margin: var(--space-sm) 0 0;
    font-size: 0.9rem;
    color: var(--color-text-tertiary);
  }

  .lab-links {
    margin: 0 0 var(--space-lg);
    padding: var(--space-md);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    background: color-mix(in srgb, var(--tut-intermediate) 6%, var(--color-surface));
  }

  .lab-links h2 {
    margin: 0 0 var(--space-xs);
    font-size: 1.05rem;
  }

  .lab-links p {
    margin: 0 0 var(--space-sm);
    font-size: 0.95rem;
    color: var(--color-text-secondary);
  }

  .lab-links-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .lab-link {
    display: inline-flex;
    align-items: center;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: 0.35rem 0.75rem;
    font-size: 0.82rem;
    text-decoration: none;
    color: var(--color-text);
    background: var(--color-surface);
  }

  .lab-link:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .related-blogs {
    margin: 0 0 var(--space-lg);
    padding: var(--space-md);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    background: color-mix(in srgb, var(--tut-beginner) 6%, var(--color-surface));
  }

  .related-blogs h2 {
    margin: 0 0 var(--space-xs);
    font-size: 1.05rem;
  }

  .related-blogs p {
    margin: 0 0 var(--space-sm);
    font-size: 0.95rem;
    color: var(--color-text-secondary);
  }

  .related-blog-list {
    margin: 0;
    padding-left: 1.2rem;
  }
</style>
