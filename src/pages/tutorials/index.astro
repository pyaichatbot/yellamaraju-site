---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TutorialPathCard from '../../components/TutorialPathCard.astro';
import TutorialCard from '../../components/TutorialCard.astro';
import LlmsDownloadButton from '../../components/LlmsDownloadButton.astro';
import { TUTORIAL_PATHS, TUTORIAL_LEVELS, tutorialHref } from '../../data/tutorial-paths';

const allTutorials = await getCollection('tutorials', ({ data }) => !data.draft);
const sortedPaths = [...TUTORIAL_PATHS].sort((a, b) => a.order - b.order);

const pathSummaries = sortedPaths.map((path) => {
  const tutorials = allTutorials.filter((t) => t.data.path === path.id);
  const levels = path.id === 'ai-literacy' ? ['Single Track'] : TUTORIAL_LEVELS
    .filter((level) => tutorials.some((t) => t.data.level === level.key))
    .map((level) => level.label);
  const recommended = TUTORIAL_LEVELS.find((level) => level.key === path.recommendedLevel)?.label ?? 'Start here';
  const recommendedLabel = path.id === 'ai-literacy' ? 'Single Track' : `Start: ${recommended}`;
  return { path, tutorials, levels, recommendedLabel };
});

const featuredTutorials = sortedPaths
  .map((path) => allTutorials
    .filter((t) => t.data.path === path.id && t.data.level === path.recommendedLevel)
    .sort((a, b) => a.data.module - b.data.module)[0])
  .filter(Boolean);
---

<BaseLayout
  title="Tutorial Learning Paths"
  description="Choose a practical learning path for GenAI foundations, production LLM systems, LangGraph, or AI system design."
  socialImage="/images/tutorials-social.png"
  socialImageWidth={1200}
  socialImageHeight={630}
  socialImageType="image/png"
>
  <div class="tutorials-hub path-hub">
    <header class="hub-header path-hero">
      <p class="eyebrow">Tutorials</p>
      <h1>Choose the learning path for what you need next.</h1>
      <p class="hub-subtitle">
        Start with the outcome, then pick the right difficulty. Each path is built for practical users: builders, testers, analysts, and product owners shipping AI systems.
      </p>
      <div class="llms-download-row">
        <LlmsDownloadButton
          href="/tutorials-llms.txt"
          filename="tutorials-llms.txt"
          label="Download tutorials-llms.txt"
        />
      </div>
      <div class="recommended-order" aria-label="Recommended learning order">
        {sortedPaths.map((path, index) => (
          <>
            <a href={`/tutorials/${path.id}`} style={`--step-color: ${path.accent}`}>{path.shortTitle}</a>
            {index < sortedPaths.length - 1 && <span aria-hidden="true">→</span>}
          </>
        ))}
      </div>
      <div class="role-filters" aria-label="Filter featured tutorials by role">
        <button class="role-filter-btn active" data-filter-role="all" aria-pressed="true">All Roles</button>
        <button class="role-filter-btn" data-filter-role="dev" aria-pressed="false">DEV</button>
        <button class="role-filter-btn" data-filter-role="qa" aria-pressed="false">QA</button>
        <button class="role-filter-btn" data-filter-role="ba" aria-pressed="false">BA</button>
        <button class="role-filter-btn" data-filter-role="pm" aria-pressed="false">PM</button>
        <button class="role-filter-btn" data-filter-role="exec" aria-pressed="false">Exec</button>
      </div>
    </header>

    <section class="path-grid" aria-label="Tutorial learning paths">
      {pathSummaries.map(({ path, tutorials, levels, recommendedLabel }) => (
        <TutorialPathCard
          title={path.title}
          description={path.description}
          audience={path.audience}
          outcome={path.outcome}
          href={`/tutorials/${path.id}`}
          accent={path.accent}
          moduleCount={tutorials.length}
          levels={levels}
          tags={path.tags}
          recommendedLabel={recommendedLabel}
        />
      ))}
    </section>

    <section class="featured-starts" aria-label="Recommended starting tutorials">
      <div class="section-heading">
        <h2>Recommended Starting Points</h2>
        <p>One first step per path. Use role filters if you are scanning for your own job-to-be-done.</p>
      </div>
      <div class="track-grid">
        {featuredTutorials.map((t) => (
          <TutorialCard
            title={t.data.title}
            description={t.data.description}
            level={t.data.level}
            module={t.data.module}
            totalModules={t.data.totalModules}
            roles={t.data.roles}
            estimatedTime={t.data.estimatedTime}
            href={tutorialHref(t)}
            levelLabel={t.data.path === 'ai-literacy' ? 'Single Track' : undefined}
          />
        ))}
      </div>
    </section>
  </div>
</BaseLayout>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const buttons = document.querySelectorAll('.role-filter-btn');
    const cards = document.querySelectorAll('.tutorial-card');

    function applyFilter(role) {
      cards.forEach((card) => {
        const roles = (card.getAttribute('data-roles') || '').split(',');
        const show = role === 'all' || roles.includes(role);
        card.style.display = show ? '' : 'none';
      });
    }

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const role = btn.getAttribute('data-filter-role') || 'all';
        buttons.forEach((b) => {
          b.classList.remove('active');
          b.setAttribute('aria-pressed', 'false');
        });
        btn.classList.add('active');
        btn.setAttribute('aria-pressed', 'true');
        applyFilter(role);
      });
    });
  });
</script>

<style>
  .tutorials-hub { max-width: 1180px; margin: 0 auto; padding: var(--space-xl) var(--space-md); }
  .path-hero { text-align: left; margin-bottom: var(--space-xl); }
  .eyebrow { margin: 0 0 var(--space-xs); color: var(--color-accent); font-family: var(--font-mono); font-size: 0.78rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; }
  .hub-header h1 { max-width: 780px; font-size: clamp(2.3rem, 7vw, 4.8rem); line-height: 0.96; margin-bottom: var(--space-md); letter-spacing: -0.055em; }
  .hub-subtitle { font-size: 1.08rem; color: var(--color-text-secondary); max-width: 720px; margin: 0 0 var(--space-md); line-height: 1.65; }
  .llms-download-row { display: flex; align-items: center; margin: calc(var(--space-sm) * -0.25) 0 var(--space-sm); }
  .recommended-order { display: flex; align-items: center; gap: 0.55rem; flex-wrap: wrap; margin: var(--space-md) 0; font-family: var(--font-sans); }
  .recommended-order a { border: 1px solid color-mix(in srgb, var(--step-color) 32%, var(--color-border)); border-radius: 999px; color: var(--step-color); background: color-mix(in srgb, var(--step-color) 7%, var(--color-surface)); padding: 0.34rem 0.75rem; font-size: 0.84rem; font-weight: 700; text-decoration: none; }
  .recommended-order span { color: var(--color-text-tertiary); }
  .role-filters { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-top: var(--space-sm); }
  .role-filter-btn { border: 1px solid var(--color-border); background: var(--color-surface); color: var(--color-text-secondary); border-radius: 999px; padding: 0.3rem 0.8rem; font-size: 0.78rem; font-weight: 700; cursor: pointer; font-family: var(--font-mono); }
  .role-filter-btn.active { border-color: var(--color-accent); color: var(--color-accent); background: color-mix(in srgb, var(--color-accent) 8%, var(--color-surface)); }
  .path-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: var(--space-md); margin-bottom: var(--space-xl); }
  .featured-starts { margin-top: var(--space-xl); }
  .section-heading { display: flex; justify-content: space-between; gap: var(--space-md); align-items: end; margin-bottom: var(--space-md); }
  .section-heading h2 { margin: 0; font-size: 1.6rem; }
  .section-heading p { margin: 0; max-width: 520px; color: var(--color-text-secondary); font-size: 0.95rem; line-height: 1.5; }
  .track-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: var(--space-md); }
  @media (max-width: 760px) { .path-grid { grid-template-columns: 1fr; } .section-heading { display: block; } }
</style>
