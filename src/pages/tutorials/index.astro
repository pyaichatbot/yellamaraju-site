---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TutorialCard from '../../components/TutorialCard.astro';

const allTutorials = await getCollection('tutorials', ({ data }) => !data.draft);

const byLevel = {
  beginner: allTutorials.filter(t => t.data.level === 'beginner').sort((a,b) => a.data.module - b.data.module),
  intermediate: allTutorials.filter(t => t.data.level === 'intermediate').sort((a,b) => a.data.module - b.data.module),
  advanced: allTutorials.filter(t => t.data.level === 'advanced').sort((a,b) => a.data.module - b.data.module),
};

const levels = [
  { key: 'beginner', label: 'Beginner', subtitle: 'From Zero to First AI App', color: 'var(--tut-beginner)', time: '15–20 min each' },
  { key: 'intermediate', label: 'Intermediate', subtitle: 'Build Real AI Features', color: 'var(--tut-intermediate)', time: '25–30 min each' },
  { key: 'advanced', label: 'Advanced', subtitle: 'Production-Grade AI Systems', color: 'var(--tut-advanced)', time: '35–45 min each' },
] as const;
---

<BaseLayout title="GenAI Tutorials" description="Progressive GenAI tutorials for DEVs, QAs, BAs, and PMs — from zero to production AI systems.">
  <div class="tutorials-hub">
    <header class="hub-header">
      <h1>GenAI Tutorials</h1>
      <p class="hub-subtitle">
        Practical, progressive tutorials for everyone building with AI — developers, QA engineers,
        business analysts, and product managers.
      </p>
      <div class="hub-roles">
        {['DEV', 'QA', 'BA', 'PM'].map(r => (
          <span class="hub-role-pill" data-role={r.toLowerCase()}>{r}</span>
        ))}
      </div>
    </header>

    {levels.map(({ key, label, subtitle, color, time }) => (
      <section class="track-section" id={key}>
        <div class="track-header">
          <div class="track-meta">
            <span class="track-level-dot" style={`background: ${color}`} />
            <div>
              <h2 class="track-title">{label}</h2>
              <p class="track-subtitle">{subtitle} · {byLevel[key].length} tutorials · {time}</p>
            </div>
          </div>
          <a href={`/tutorials/${key}`} class="track-cta">View Track →</a>
        </div>
        <div class="track-grid">
          {byLevel[key].map(t => (
            <TutorialCard
              title={t.data.title}
              description={t.data.description}
              level={t.data.level}
              module={t.data.module}
              totalModules={t.data.totalModules}
              roles={t.data.roles}
              estimatedTime={t.data.estimatedTime}
              href={`/tutorials/${t.data.level}/${t.slug.replace(`${t.data.level}/`, '')}`}
            />
          ))}
        </div>
      </section>
    ))}
  </div>
</BaseLayout>

<style>
  .tutorials-hub { max-width: 1100px; margin: 0 auto; padding: var(--space-xl) var(--space-md); }

  .hub-header { text-align: center; margin-bottom: var(--space-xl); }
  .hub-header h1 { font-size: 2.5rem; margin-bottom: var(--space-sm); }
  .hub-subtitle { font-size: 1.1rem; color: var(--color-text-secondary); max-width: 600px; margin: 0 auto var(--space-md); }

  .hub-roles { display: flex; justify-content: center; gap: 0.5rem; flex-wrap: wrap; }
  .hub-role-pill { font-size: 0.8rem; font-weight: 700; padding: 0.3rem 0.8rem; border-radius: 999px; font-family: var(--font-mono); border: 1px solid var(--color-border); }

  .track-section { margin-bottom: var(--space-xl); }

  .track-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: var(--space-md); flex-wrap: wrap; gap: var(--space-sm); }
  .track-meta { display: flex; align-items: center; gap: var(--space-sm); }
  .track-level-dot { width: 12px; height: 12px; border-radius: 50%; flex-shrink: 0; }
  .track-title { font-size: 1.5rem; margin: 0; }
  .track-subtitle { font-size: 0.9rem; color: var(--color-text-secondary); margin: 0.2rem 0 0; }
  .track-cta { font-size: 0.9rem; color: var(--color-accent); text-decoration: none; font-weight: 600; }
  .track-cta:hover { text-decoration: underline; }

  .track-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: var(--space-md); }

  @media (max-width: 640px) { .track-grid { grid-template-columns: 1fr; } }
</style>
