---
import BaseLayout from '../layouts/BaseLayout.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
---

<BaseLayout
  title="Newsletter"
  description="Subscribe for new articles on AI architecture, agentic systems, and production AI engineering."
>
  <div class="newsletter-page">
    <div class="container">
      <div class="content-wrapper">
        <header class="page-header">
          <h1>Newsletter</h1>
          <p>
            Monthly insights on AI architecture, production LLM systems, and practical engineering patterns.
          </p>
        </header>
        <div id="newsletter-status-banner" class="status-banner" hidden aria-live="polite"></div>

        <NewsletterSignup source="newsletter-page" />

        <section class="newsletter-details">
          <h2>What You Get</h2>
          <ul>
            <li>New blog posts and series updates</li>
            <li>Production checklists and practical frameworks</li>
            <li>Curated references from real implementation work</li>
          </ul>
          <p>
            Prefer feed readers? Use the <a href="/blog/rss.xml">RSS feed</a>.
          </p>
        </section>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  const banner = document.getElementById('newsletter-status-banner');
  const params = new URLSearchParams(window.location.search);
  const status = params.get('status');

  if (banner && status) {
    if (status === 'check-email') {
      banner.textContent = 'Check your inbox and click the confirmation link to finish subscribing.';
      banner.classList.add('status-pending');
      banner.hidden = false;
    }
    if (status === 'confirmed') {
      banner.textContent = 'Subscription confirmed. Welcome to the newsletter.';
      banner.classList.add('status-success');
      banner.hidden = false;
    }
  }
</script>

<style>
  .newsletter-page {
    padding: var(--space-lg) 0 var(--space-xl);
  }

  .page-header {
    text-align: center;
    margin-bottom: var(--space-lg);
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid var(--color-border);
  }

  .page-header h1 {
    font-size: 2.5rem;
    margin-bottom: var(--space-xs);
  }

  .page-header p {
    margin: 0 auto;
    max-width: 700px;
    color: var(--color-text-secondary);
  }

  .newsletter-details {
    margin-top: var(--space-xl);
    padding: var(--space-lg);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
  }

  .newsletter-details h2 {
    margin-top: 0;
    margin-bottom: var(--space-sm);
  }

  .newsletter-details ul {
    margin-top: 0;
    margin-bottom: var(--space-md);
  }

  .newsletter-details p {
    margin: 0;
    color: var(--color-text-secondary);
  }

  .newsletter-details a {
    color: var(--color-accent);
  }

  .status-banner {
    margin: 0 auto var(--space-md);
    max-width: 720px;
    padding: 0.75rem 1rem;
    border-radius: 8px;
    border: 1px solid var(--color-border);
    font-family: var(--font-sans);
    font-size: 0.95rem;
    text-align: center;
  }

  .status-banner.status-pending {
    background: rgba(37, 99, 235, 0.08);
    border-color: rgba(37, 99, 235, 0.25);
    color: var(--color-text);
  }

  .status-banner.status-success {
    background: rgba(16, 185, 129, 0.1);
    border-color: rgba(16, 185, 129, 0.3);
    color: var(--color-text);
  }
</style>
