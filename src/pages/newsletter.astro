---
import BaseLayout from '../layouts/BaseLayout.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
---

<BaseLayout
  title="Newsletter"
  description="Subscribe for new articles on AI architecture, agentic systems, and production AI engineering."
>
  <div class="newsletter-page">
    <div class="container">
      <div class="content-wrapper">
        <header class="page-header">
          <h1>Newsletter</h1>
          <p>
            Monthly insights on AI architecture, production LLM systems, and practical engineering patterns.
          </p>
        </header>

        <NewsletterSignup source="newsletter-page" />

        <section class="newsletter-details">
          <h2>What You Get</h2>
          <ul>
            <li>New blog posts and series updates</li>
            <li>Production checklists and practical frameworks</li>
            <li>Curated references from real implementation work</li>
          </ul>
          <p>
            Prefer feed readers? Use the <a href="/blog/rss.xml">RSS feed</a>.
          </p>
        </section>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .newsletter-page {
    padding: var(--space-lg) 0 var(--space-xl);
  }

  .page-header {
    text-align: center;
    margin-bottom: var(--space-lg);
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid var(--color-border);
  }

  .page-header h1 {
    font-size: 2.5rem;
    margin-bottom: var(--space-xs);
  }

  .page-header p {
    margin: 0 auto;
    max-width: 700px;
    color: var(--color-text-secondary);
  }

  .newsletter-details {
    margin-top: var(--space-xl);
    padding: var(--space-lg);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
  }

  .newsletter-details h2 {
    margin-top: 0;
    margin-bottom: var(--space-sm);
  }

  .newsletter-details ul {
    margin-top: 0;
    margin-bottom: var(--space-md);
  }

  .newsletter-details p {
    margin: 0;
    color: var(--color-text-secondary);
  }

  .newsletter-details a {
    color: var(--color-accent);
  }
</style>
